# Authentication method: 'oauth' (default) or 'github-app'
# oauth = GitHub OAuth App (broad 'repo' scope, no app installation needed per org)
# github-app = GitHub App (granular read-only permissions, must be installed per org)
AUTH_METHOD=oauth

# GitHub OAuth App credentials (used when AUTH_METHOD=oauth)
# Register at: https://github.com/settings/applications/new
# Set "Authorization callback URL" to your dashboard URL (e.g., https://yourdomain.com/)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# GitHub App credentials (used when AUTH_METHOD=github-app)
# Register at: https://github.com/settings/apps/new
# Required permissions: Actions (read), Metadata (read), Organization Members (read)
# Set "Callback URL" to your dashboard URL (e.g., https://yourdomain.com/)
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
